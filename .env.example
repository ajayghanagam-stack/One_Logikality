# One Logikality — environment variables (commit this file; never commit .env)
# Variable names match Title Intelligence Hub per docs/TechStack.md §14.

# --- Database (Postgres 5437 in docker-compose) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5437/one_logikality

# --- Temporal (7234 in docker-compose, offset from TI Hub's 7233) ---
TEMPORAL_ADDRESS=localhost:7234

# --- Auth ---
# INSECURE development default. Override in .env; replace entirely in any non-local environment.
JWT_SECRET=dev-insecure-change-me-before-production
JWT_EXPIRATION_MINUTES=1440

# --- Object storage (local filesystem by default; switch to s3 when S3_ENDPOINT/etc. are set) ---
STORAGE_PROVIDER=local
STORAGE_PATH=./storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Pipeline orchestration ---
PIPELINE_BACKEND=temporal

# --- AI providers (required starting in Step 4 / Phase 3 ECV; leave unset until then) ---
AI_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_REGION=us-central1
