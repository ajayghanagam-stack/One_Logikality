# One Logikality — environment variables (commit this file; never commit .env)
# Variable names match Title Intelligence Hub per docs/TechStack.md §14.

# --- Database (Postgres 5437 in docker-compose) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5437/one_logikality

# --- Temporal (7234 in docker-compose, offset from TI Hub's 7233) ---
TEMPORAL_ADDRESS=localhost:7234

# --- Auth ---
# INSECURE development default. Override in .env; replace entirely in any non-local environment.
JWT_SECRET=dev-insecure-change-me-before-production
JWT_EXPIRATION_MINUTES=1440

# --- Object storage (local filesystem by default; switch to s3 when S3_ENDPOINT/etc. are set) ---
STORAGE_PROVIDER=local
STORAGE_PATH=./storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Pipeline orchestration ---
PIPELINE_BACKEND=temporal

# --- AI providers (required starting in Step 4 / Phase 3 ECV) ---
AI_PROVIDER=hybrid

# Anthropic (Claude Sonnet — validation + reasoning)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Vertex AI (Gemini 2.5 Flash / Pro — classification + extraction;
# Document AI form parsing lands in M3).
# Auth: run `gcloud auth application-default login` for local dev, or set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON in CI / staging.
# Required APIs on the GCP project:
#   gcloud services enable aiplatform.googleapis.com
#   gcloud services enable documentai.googleapis.com
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_REGION=us-central1
# VERTEX_CLASSIFY_MODEL=gemini-2.5-flash
# VERTEX_EXTRACT_MODEL=gemini-2.5-pro
